{
  "cells": [
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# UFUU Higgs Parameter Fixing Verification Notebook\n",
        "\n",
        "Exact 11-step entropy-maximization procedure for the candidate fold \( F(a,b) \).\n",
        "\n",
        "This notebook reproduces the grid search under the linear eigenvalue constraint and shows \(\mu^2 = +0.741\) (single-well result).\n",
        "\n",
        "**Repository file**: UFUU_Higgs_Verification.ipynb  \n",
        "**Companion to**: UFUU_Higgs_Verification.py"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "source": [
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "from scipy.stats import gaussian_kde\n",
        "import warnings\n",
        "warnings.filterwarnings('ignore')\n",
        "\n",
        "print('Imports complete.')"
      ],
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 🧩 1. Notebook header: constants, imports, fixed-point values"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "source": [
        "# 1. Constants and fixed-point values\n",
        "ATTRACTOR_M = 1.134663          # numerical value of the attractor from UFUU notes\n",
        "LAMBDA_SYM = 0.259              # target eigenvalue of linearized transfer operator\n",
        "N_SAMPLES = 10000\n",
        "N_ITER = 12\n",
        "PHI_STD = 0.01                  # small Gaussian perturbation around symmetric point\n",
        "\n",
        "print(f'ATTRACTOR_M = {ATTRACTOR_M}')\n",
        "print(f'LAMBDA_SYM  = {LAMBDA_SYM}')"
      ],
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 🧩 2. Define the fold and the reduced-map"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "source": [
        "# 2. Define the effective recursion map (from Taylor expansion)\n",
        "def effective_map(phi, alpha, beta, m, gamma):\n",
        "    \"\"\"Effective recursion map for the order parameter φ.\"\"\"\n",
        "    linear_coeff = 2 * alpha + 2 * beta * m**2\n",
        "    cubic_coeff = -2 * beta + 8 * gamma\n",
        "    return linear_coeff * phi + cubic_coeff * phi**3\n",
        "\n",
        "print('effective_map defined.')"
      ],
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 🧩 3. Parameter domain definition"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "source": [
        "# 3. Parameter domain definition\n",
        "beta_range = np.linspace(-0.05, 0.05, 21)\n",
        "gamma_range = np.linspace(0.0, 0.2, 21)\n",
        "\n",
        "# Compute alpha from the linear constraint for each beta (at fixed m)\n",
        "alpha_range = (LAMBDA_SYM - 2 * beta_range[:, None] * ATTRACTOR_M**2) / 2\n",
        "\n",
        "# Enforce stability λ > 0\n",
        "def lambda_coeff(b, g):\n",
        "    return 2 * b - 8 * g\n",
        "\n",
        "stable_mask = lambda_coeff(beta_range[:, None], gamma_range) > 0\n",
        "\n",
        "print(f'Parameter grid ready: {len(beta_range)} × {len(gamma_range)} points')"
      ],
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 🧩 4. Initial distribution for φ"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "source": [
        "# 4. Initial distribution for φ\n",
        "np.random.seed(42)\n",
        "phi0 = np.random.normal(0, PHI_STD, N_SAMPLES)\n",
        "\n",
        "print(f'Initial Gaussian distribution generated: {N_SAMPLES} samples, std = {PHI_STD}')"
      ],
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 🧩 5–6. Iterate the map and track distributions + Compute Shannon entropy"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "source": [
        "# 5-6. Iterate the map and compute Shannon entropy\n",
        "def compute_final_entropy(alpha, beta, gamma, m=ATTRACTOR_M, n_iter=N_ITER):\n",
        "    phi = phi0.copy()\n",
        "    for _ in range(n_iter):\n",
        "        phi = effective_map(phi, alpha, beta, m, gamma)\n",
        "    \n",
        "    # Histogram-based Shannon entropy (robust approximation)\n",
        "    hist, bin_edges = np.histogram(phi, bins=100, density=True)\n",
        "    hist = hist[hist > 1e-12]\n",
        "    bin_width = bin_edges[1] - bin_edges[0]\n",
        "    entropy = -np.sum(hist * np.log2(hist)) * bin_width\n",
        "    return entropy\n",
        "\n",
        "print('compute_final_entropy function ready.')"
      ],
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 🧩 7. Entropy maximization over the parameter grid"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "source": [
        "# 7. Entropy maximization over the parameter grid\n",
        "entropies = np.full((len(beta_range), len(gamma_range)), -np.inf)\n",
        "max_entropy = -np.inf\n",
        "best_alpha = best_beta = best_gamma = None\n",
        "\n",
        "for i, beta in enumerate(beta_range):\n",
        "    for j, gamma in enumerate(gamma_range):\n",
        "        if not stable_mask[i, j]:\n",
        "            continue\n",
        "        alpha = (LAMBDA_SYM - 2 * beta * ATTRACTOR_M**2) / 2\n",
        "        ent = compute_final_entropy(alpha, beta, gamma)\n",
        "        entropies[i, j] = ent\n",
        "        if ent > max_entropy:\n",
        "            max_entropy = ent\n",
        "            best_alpha = alpha\n",
        "            best_beta = beta\n",
        "            best_gamma = gamma\n",
        "\n",
        "print('Grid search completed.')"
      ],
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 🧩 8–9. Compute Higgs-sector parameters from the selected triple"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "source": [
        "# 8-9. Compute Higgs-sector parameters\n",
        "mu2 = 1 - (2 * best_alpha + 2 * best_beta * ATTRACTOR_M**2)\n",
        "lambda_higgs = 2 * best_beta - 8 * best_gamma\n",
        "\n",
        "print(f'Best parameters selected: α={best_alpha:.5f}, β={best_beta:.5f}, γ={best_gamma:.5f}')\n",
        "print(f'μ² = {mu2:.5f}  (positive → symmetric point is stable)')\n",
        "print(f'λ  = {lambda_higgs:.5f}  (positive → broken vacua are stable)')"
      ],
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 🧩 10–11. Visualizations + Output summary"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "source": [
        "# 11. Final summary\n",
        "print(\"\\n=== UFUU Higgs Parameter Fixing Results ===\")\n",
        "print(f\"Best parameters (entropy-maximizing):\")\n",
        "print(f\"  α = {best_alpha:.5f}\")\n",
        "print(f\"  β = {best_beta:.5f}\")\n",
        "print(f\"  γ = {best_gamma:.5f}\")\n",
        "print(f\"  Max Shannon entropy ≈ {max_entropy:.4f}\")\n",
        "print(f\"μ² = {mu2:.5f}  (positive → symmetric point is stable)\")\n",
        "print(f\"λ  = {lambda_higgs:.5f}  (positive → broken vacua are stable)\")\n",
        "print(f\"Double-well condition (μ² < 0) is NOT satisfied in this run.\")\n",
        "\n",
        "# Optional: save grid for later analysis\n",
        "np.savez(\"higgs_entropy_grid.npz\", beta=beta_range, gamma=gamma_range, entropies=entropies)\n",
        "print(\"\\nGrid saved to higgs_entropy_grid.npz\")"
      ],
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Conclusion\n",
        "\n",
        "The grid search under the current linear constraint yields **μ² ≈ +0.741** (single-well potential).\n",
        "This confirms the open question stated in the paper: the double-well condition requires either relaxing the symmetric-point constraint or identifying a nonzero attractor \( m \) from first principles.\n",
        "\n",
        "The notebook is fully reproducible and ready for the repository."
      ]
    }
  ],
